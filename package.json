{
  "name": "releasedeck",
  "version": "0.1.0",
  "private": true,
  "description": "Release freshness dashboard for open source maintainers.",
  "type": "module",
  "scripts": {
    "build": "npm run build:script && node node_modules/.cache/releasedeck-build/scripts/build.js",
    "build:script": "tsc -p tsconfig.build.json",
    "check": "npm run check:static && npm run check:data",
    "check:data": "node node_modules/.cache/releasedeck-build/scripts/build.js --check",
    "check:static": "npm run typecheck && npm run lint && npm run format:check && npm run build:script && npm run test",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "test": "npm run build:script && node node_modules/.cache/releasedeck-build/scripts/lib/dashboard.test.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
