{
  "name": "releasebar",
  "version": "0.1.0",
  "private": true,
  "description": "Release freshness dashboard for open source maintainers.",
  "type": "module",
  "scripts": {
    "build": "npm run build:script && npm run build:app && node node_modules/.cache/releasebar-build/scripts/build.js",
    "build:app": "vite build",
    "build:assets": "node node_modules/.cache/releasebar-build/scripts/build.js --assets-only",
    "build:script": "tsc -p tsconfig.build.json",
    "check": "npm run check:static && npm run check:data",
    "check:data": "node node_modules/.cache/releasebar-build/scripts/build.js --check",
    "check:static": "npm run typecheck && npm run lint && npm run format:check && npm run build:script && npm run build:app && npm run build:assets && npm run test",
    "dev": "vite dev --host 127.0.0.1",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "test": "npm run build:script && node node_modules/.cache/releasebar-build/scripts/lib/dashboard.test.js",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.svelte.json"
  },
  "dependencies": {
    "bits-ui": "^2.18.1",
    "svelte": "^5.55.7",
    "svelte-command-palette": "^2.0.2",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.8.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "engines": {
    "node": ">=20"
  }
}
